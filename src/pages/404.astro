---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | LT's Mobile Mechanics"
  description="The page you're looking for doesn't exist. Return to the LT's Mobile Mechanics home page or give us a call at (971) 534-0360."
  canonical="https://ltsmobilemechanics.com/404/"
>
  <main>
    <section class="article-hero">
      <div class="container">
        <h1>Page <em>Not Found</em></h1>
        <p class="hero-subtitle">We could not find the page you were looking for. It may have moved or no longer exist.</p>
      </div>
    </section>

    <section class="container" style="padding:48px 0 96px;">
      <div class="article-cta" style="margin:0 auto;max-width:680px;">
        <h2>Need Help Finding Something?</h2>
        <p>Head back to the home page, or call us directly — we are happy to point you in the right direction.</p>
        <div class="cta-buttons">
          <a href="/" class="btn btn-gold">Back to Home</a>
          <a href="tel:+19715340360" class="btn btn-outline">Call (971) 534-0360</a>
        </div>
      </div>
    </section>
  </main>
</Layout>
