---
import Layout from '../../layouts/Layout.astro';
import ArticleCTA from '../../components/ArticleCTA.astro';
import RelatedServices from '../../components/RelatedServices.astro';
import RelatedAreas from '../../components/RelatedAreas.astro';

const SITE = 'https://ltsmobilemechanics.com';
const city = 'Clackamas';
const slug = 'clackamas';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `LT's Mobile Mechanics - ${city}`,
  "image": `${SITE}/og-image.png`,
  "description": `Mobile mechanic services in ${city}, Oregon. Professional auto repair, diagnostics, and maintenance delivered to your location. Available 24/7.`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "4041 SW Hall Blvd",
    "addressLocality": "Beaverton",
    "addressRegion": "OR",
    "postalCode": "97005",
    "addressCountry": "US"
  },
  "telephone": "+19715340360",
  "email": "ltsmobilepdx@gmail.com",
  "url": `${SITE}/areas/${slug}/`,
  "areaServed": { "@type": "City", "name": `${city}, Oregon` },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "priceRange": "$$"
};
---

<Layout
  title={`Mobile Mechanic in ${city}, Oregon | LT's Mobile Mechanics`}
  description={`Professional mobile mechanic services in ${city}, Oregon. Oil changes, brake repair, diagnostics, and more. We come to you. Call (971) 534-0360.`}
  keywords={`mobile mechanic ${city}, auto repair ${city} Oregon, mechanic near me ${city}, car repair ${city}`}
  canonical={`https://ltsmobilemechanics.com/areas/${slug}/`}
  schema={schema}
>
  <main>
    <section class="article-hero">
      <div class="container">
        <h1>Mobile Mechanic in <em>{city}</em>, Oregon</h1>
        <p class="hero-subtitle">Professional auto repair that comes to you — 24/7.</p>
      </div>
    </section>

    <section class="container">
      <article class="article-body">
        <div class="article-content fade-up">
          <p>
            Clackamas is a growing community with a strong commercial center and family-oriented neighborhoods. The area around Clackamas Town Center draws thousands of shoppers daily, and along Sunnyside Road and throughout the broader community, residents need reliable auto repair services. LTs Mobile Mechanics serves the Clackamas area with professional mechanic services that come directly to you, eliminating the need to visit a traditional repair shop.
          </p>

          <p>
            The proximity to Happy Valley and the I-205 corridor makes Clackamas a convenient hub for people working throughout the Portland metro area. Whether you're managing a busy household with multiple vehicles or running a business that depends on reliable transportation, LTs Mobile Mechanics understands the Clackamas lifestyle. We're not just another repair service, we're a local option that brings professional expertise directly to your home or office, saving you time and hassle.
          </p>

          <p>
            Clackamas Town Center has become more than just a shopping destination, it represents the community's growth and vitality. That same commitment to excellence drives LTs Mobile Mechanics. We handle every repair with attention to detail, whether it's a routine oil change, brake repair, battery work, or comprehensive vehicle diagnostics. Our mobile mechanic service means you can have your vehicle serviced without disrupting your day. We come equipped with the tools and expertise to handle whatever your vehicle needs.
          </p>

          <p>
            The I-205 corridor is vital to the Clackamas area, connecting residents to opportunities throughout the region. That's why reliable vehicles are essential here. Whether you need spark plug replacement, suspension work, an alternator check, or a pre-purchase inspection before buying a used vehicle, LTs Mobile Mechanics has you covered. We diagnose problems accurately, explain our findings clearly, and provide honest recommendations without unnecessary upselling.
          </p>

          <p>
            What sets LTs Mobile Mechanics apart in the Clackamas area is our commitment to quality service at fair prices. We understand that vehicle maintenance is an expense, and we work hard to keep that expense reasonable while maintaining the highest standards of workmanship. Tristan Matthew and his team have built a reputation on integrity, and that's what you get every time you call us. Fair pricing, transparent communication, and professional service are not negotiable.
          </p>

          <p>
            Emergencies don't follow business hours, which is why LTs Mobile Mechanics operates 24/7. Whether it's a weekend breakdown, a holiday battery issue, or a middle-of-the-night emergency, we're here for you. Call us anytime, and we'll dispatch a professional mechanic to help you get back on the road. That's the kind of reliability and dedication that Clackamas residents deserve.
          </p>
        </div>
      </article>
    </section>

    <ArticleCTA
      heading={`Need a Mobile Mechanic in ${city}?`}
      subheading={`Call LT's Mobile Mechanics. We come to you anywhere in ${city} — any time, day or night.`}
    />

    <RelatedServices heading={`Our Services in ${city}`} />

    <RelatedAreas exclude={slug} />
  </main>
</Layout>
